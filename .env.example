# ─────────────────────────────────────────────────────────────────────────────
# HRMS Backend – Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/hrms_db

# Set to "true" to enable SQLAlchemy query logging (dev only)
DB_ECHO=false

# FastAPI secret key (used for JWT / session signing)
SECRET_KEY=replace-me-with-a-long-random-string

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App environment: development | staging | production
APP_ENV=development

# API host / port (used by uvicorn)
HOST=0.0.0.0
PORT=8000
